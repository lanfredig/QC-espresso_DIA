#| label: Denovo peptides filtered Venn diagrams
pep.denovo.venn.ON <- pep.denovo.intensity %>%
filter(str_detect(Run, "ON")) %>%
group_by(Run) %>%
summarise(Pep = list(unique(unlist(Peptide)))) %>%
deframe()
pep.denovo.venn.OFF <- pep.denovo.intensity %>%
filter(str_detect(Run, "OFF")) %>%
group_by(Run) %>%
summarise(Pep = list(unique(unlist(Peptide)))) %>%
deframe()
