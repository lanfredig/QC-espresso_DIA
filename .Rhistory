left_join(denovo.score, join_by(Source.File, Peptide)) %>%
filter(SCORE....> 80, Length >7) %>%
group_by(Source.File) %>%
count()
pep.denovo.ids.stats <- data.frame(v_max = nrow(pep.denovo.ids),
v_medio = mean(pep.denovo.ids.count$n))
ggplot(data = pep.denovo.ids.count, aes(x = Source.File, y = n)) +
geom_col(color = "black", fill = "gray85") +
geom_hline(data = pep.denovo.ids.stats, aes(yintercept = v_medio),
color = "blue", linetype = "dotted", size = 1) +
geom_text(data = pep.denovo.ids.stats, aes(x = 0.5, y = v_medio, label = "AVG"),
color = "blue", fontface = "bold", size = 3, vjust = -1.5, hjust = 0) +
geom_text(data = pep.denovo.ids.stats, aes(x = 0.5, y = v_medio,
label = paste0("(", round(v_medio, 0), ")")),
color = "blue", size = 3, vjust = 2, hjust = 0) +
theme_minimal() +
labs(title = "Number of Identifications", x = "Sample", y = "Total Count") +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
